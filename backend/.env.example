PORT=8787
NODE_ENV=development

# Enoki — zkLogin + sponsored transactions
ENOKI_API_KEY=

# Sui
SUI_NETWORK=testnet
SUI_PACKAGE_ID=
SUI_REWARDS_ENGINE_ID=
SUI_ORACLE_CAP_ID=
SUI_VERSION_OBJECT_ID=

# Oracle signer — ed25519 key used to sign workout attestations.
# In production this lives in an HSM / KMS. For local dev, generate with:
#   sui keytool generate ed25519 --key-scheme ed25519
ORACLE_PRIVATE_KEY_HEX=
ORACLE_PUBLIC_KEY_HEX=

# Apple — used to verify App Attest assertions against Apple's root CA.
APPLE_APP_ID=FX9AP8JB22.gimme.coffee.iHealth
APPLE_TEAM_ID=FX9AP8JB22

# Walrus
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_WAL_TREASURY_KEY=
